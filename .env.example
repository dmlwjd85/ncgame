# 로컬 개발: 이 파일을 복사해 `.env` 또는 `.env.local` 로 저장한 뒤 값을 맞춥니다.
# 프로덕션 빌드는 `.env.production`을 사용합니다.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# 마스터 로그인 (선택) — VITE_MASTER_AUTH_EMAIL과 동일한 계정을 Firebase Authentication에 먼저 만듭니다.
VITE_MASTER_DISPLAY_NAME=
VITE_MASTER_PASSWORD=
VITE_MASTER_AUTH_EMAIL=
