{
  "name": "ncgame",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:cap": "npx cross-env VITE_BASE_PATH=/ vite build && npx cap sync",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "npm run lint && npm run build",
    "ncxlxs:split": "node scripts/split-ncxlxs-one-sheet-per-file.mjs",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "android:sync": "npm run build:cap",
    "android:aab": "npm run build:cap && node scripts/run-android-gradle.mjs bundleRelease",
    "android:apk": "npm run build:cap && node scripts/run-android-gradle.mjs assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "7.1.0",
    "@capacitor/app": "7.1.0",
    "@capacitor/core": "7.1.0",
    "@capacitor/ios": "7.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "firebase": "^12.12.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@capacitor/cli": "7.1.0",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-tools": "^14.27.0",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.4"
  }
}
