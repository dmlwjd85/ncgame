rules_version = '2';
// sambong-world-2026 단일 Firestore — 삼봉 월드(artifacts) + ncgame(loginByName, users) 통합 규칙
// 배포: ncgame 또는 2026sambong6에서 firebase deploy --only firestore (동일 프로젝트면 한 번이면 됨)
//
// ★ ncgame 마스터: 클라이언트는 기본적으로 ncgame-master@{projectId}.firebaseapp.com 이메일을 씁니다.
//    (선택) 예전 방식으로 REPLACE_NCGAME_MASTER_EMAIL 을 쓰는 경우 해당 문자열로 바꿔 배포하세요.
//    (선택) VITE_MASTER_UIDS 로 추가 마스터: REPLACE_OPTIONAL_MASTER_UID 를 해당 UID 로.

service cloud.firestore {
  match /databases/{database}/documents {

    function isNcgameMasterBuiltinEmail() {
      return request.auth != null
        && request.auth.token.email.matches('^ncgame-master@[a-z0-9-]+\\.firebaseapp\\.com$');
    }

    function isNcgameMaster() {
      return request.auth != null && (
        isNcgameMasterBuiltinEmail()
        || request.auth.token.email == 'REPLACE_NCGAME_MASTER_EMAIL'
        || request.auth.uid == 'REPLACE_OPTIONAL_MASTER_UID'
      );
    }
    // --- 삼봉 월드 (2026sambong6 / sambongWorld.js) ---
    match /artifacts/{appId}/public/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- ncgame (이름·비밀번호 회원가입) ---
    match /loginByName/{name} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      // 표시 이름 변경 시 본인 문서만 삭제 후 새 이름으로 재등록
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isNcgameMaster());
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if isNcgameMaster();
    }

    // --- ncgame 명예의 전당 (팩별 서브컬렉션) ---
    match /ncgameHofByPack/{packId}/entries/{uid} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.packId == packId;
      allow delete: if false;
    }

    // 무한도전(콤보) 명예의 전당
    match /ncgameHofComboByPack/{packId}/entries/{uid} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.packId == packId;
      allow delete: if false;
    }

    // 마스터 최초 설정 완료 플래그 — 읽기는 누구나(로그인 화면), 생성은 해당 이메일로 막 생성된 인증 사용자만 1회
    match /system/masterSetup {
      allow read: if true;
      allow create: if !exists(/databases/$(database)/documents/system/masterSetup)
        && request.resource.data.completed == true
        && request.auth != null
        && (
          isNcgameMasterBuiltinEmail()
          || request.auth.token.email == 'REPLACE_NCGAME_MASTER_EMAIL'
        );
      allow update, delete: if isNcgameMaster();
    }

    // 활동 로그 — 본인만 생성, 마스터만 읽기·삭제
    match /ncgameActivityLog/{logId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow read: if isNcgameMaster();
      allow delete: if isNcgameMaster();
    }
  }
}
