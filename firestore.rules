rules_version = '2';
// sambong-world-2026 단일 Firestore — 삼봉 월드(artifacts) + ncgame(loginByName, users) 통합 규칙
// 배포: ncgame 또는 2026sambong6에서 firebase deploy --only firestore (동일 프로젝트면 한 번이면 됨)

service cloud.firestore {
  match /databases/{database}/documents {
    // --- 삼봉 월드 (2026sambong6 / sambongWorld.js) ---
    match /artifacts/{appId}/public/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- ncgame (이름·비밀번호 회원가입) ---
    match /loginByName/{name} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    // --- ncgame 명예의 전당 (팩별 서브컬렉션) ---
    match /ncgameHofByPack/{packId}/entries/{uid} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.packId == packId;
      allow delete: if false;
    }
  }
}
